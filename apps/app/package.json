{
  "name": "@saas-boilerplate/app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "CLOUDFLARE_ENV=local vite dev --port 3000",
    "build": "vite build",
    "preview": "bun run build && vite preview",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "deploy": "CLOUDFLARE_ENV=production bun run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "bun x auth@latest generate --config ./src/lib/auth-cli.ts --output ./src/db/schema/auth.ts --yes",
    "start": "node dist/server/index.js",
    "cf-typegen": "wrangler types --env local"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.42.0",
    "@posthog/react": "^1.10.2",
    "@saas-boilerplate/ui": "workspace:*",
    "@sentry/cloudflare": "^10.58.0",
    "@sentry/tanstackstart-react": "^10.58.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/router-plugin": "^1.168.18",
    "better-auth": "^1.6.19",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "postgres": "^3.4.9",
    "posthog-js": "^1.390.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260619.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.102.0"
  }
}
