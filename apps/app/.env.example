# SaaS Boilerplate app environment
# Copy to apps/app/.env for local development. Keep real secrets out of git.

## Database
# CLI-only. Drizzle and Better Auth generation use this URL.
# Runtime database access uses the Cloudflare HYPERDRIVE binding.
DIRECT_DATABASE_URL=postgresql://localhost/saas_boilerplate

## Auth
# Generate a long random value per environment.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## Analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

## Monitoring
VITE_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=local

## Build tooling
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
